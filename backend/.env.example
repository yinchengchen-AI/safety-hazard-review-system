# Copy this file to backend/.env and fill in real values for local development.
# Production values are managed by the deployment script (see DEPLOY.md).

# PostgreSQL - runtime swaps psycopg2 -> asyncpg automatically
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/safety_hazard

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=hazard-photos

# JWT signing key - generate with: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Auto-create tables on startup (dev only; never true in production)
AUTO_CREATE_TABLES=false
